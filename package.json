{
	"name": "indexer-cli",
	"version": "0.9.13",
	"description": "Lightweight CLI project indexer with semantic search via Ollama",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"indexer-cli": "./bin/indexer-cli.js"
	},
	"files": [
		"bin",
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsx scripts/generate-skills-version.ts && tsc",
		"dev": "tsc --watch",
		"start": "tsx bin/indexer-cli.js",
		"indexer-cli": "tsx bin/indexer-cli.js",
		"indexer-cli:init": "tsx bin/indexer-cli.js init",
		"indexer-cli:uninstall": "tsx bin/indexer-cli.js uninstall -f",
		"refresh-skills": "tsx bin/indexer-cli.js init --refresh-skills",
		"test": "vitest run tests/unit/",
		"test:full": "vitest run tests/unit/ tests/cli/ --testTimeout=180000",
		"test:watch": "vitest",
		"test:cli": "vitest run tests/cli/ --testTimeout=180000 --no-file-parallelism",
		"test:cli:python": "vitest run tests/cli/commands-python.test.ts --testTimeout=180000 --no-file-parallelism",
		"test:cli:gdscript": "vitest run tests/cli/commands-gdscript.test.ts --testTimeout=180000 --no-file-parallelism",
		"test:cli:csharp": "vitest run tests/cli/commands-csharp.test.ts --testTimeout=180000 --no-file-parallelism",
		"test:cli:ruby": "vitest run tests/cli/commands-ruby.test.ts --testTimeout=180000 --no-file-parallelism",
		"publish-npm": "bash scripts/publish.sh"
	},
	"dependencies": {
		"better-sqlite3": "^12.0.0",
		"commander": "^12.1.0",
		"p-limit": "^4.0.0",
		"proper-lockfile": "^4.1.2",
		"sqlite-vec": "^0.1.9",
		"tree-sitter": "^0.21.1",
		"tree-sitter-c-sharp": "^0.23.1",
		"tree-sitter-gdscript": "^6.1.0",
		"tree-sitter-python": "^0.21.0",
		"tree-sitter-ruby": "^0.23.1",
		"ts-morph": "^21.0.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.10.0",
		"@types/proper-lockfile": "^4.1.4",
		"@vitest/coverage-v8": "^4.1.3",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vitest": "^4.1.3"
	}
}
